# SIGIP-GB – Variables d'environnement
# ─── DEV : copier vers .env et remplir ───────────────────────────────────────

# Django
SECRET_KEY=mudar-esta-chave-secreta-em-producao-usar-openssl-rand-base64-50
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_SETTINGS_MODULE=config.settings.development

# Base de dados SQLite (dev)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db_dev.sqlite3

# Redis / Celery (dev)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=django-db

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8001


# ─── PRODUCTION Railway : variables à définir dans Railway Dashboard ─────────
#
# DJANGO_SETTINGS_MODULE=config.settings.production
# SECRET_KEY=<générer avec: python -c "import secrets; print(secrets.token_urlsafe(50))">
# DATABASE_URL=<fourni automatiquement par Railway PostgreSQL>
# ALLOWED_HOSTS=votre-app.railway.app,votre-domaine.com
# CSRF_TRUSTED_ORIGINS=https://votre-app.railway.app,https://votre-domaine.com
# CORS_ALLOWED_ORIGINS=https://votre-app.railway.app
